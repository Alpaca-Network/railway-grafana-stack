    {
      "id": 6,
      "type": "stat",
      "title": "Free Model Error Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "grafana_prometheus"
          },
          "expr": "sum(rate(model_inference_requests_total{status=\"error\"}[$__rate_interval])) / clamp_min(sum(rate(free_model_usage_total[$__rate_interval])), 0.001) * 100",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "mappings": [],
          "color": {
            "mode": "thresholds"
